# ─── Andrequicé — Variáveis de Ambiente de Produção ──────────────────────────
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA commite o .env — ele está no .gitignore.
#
# Armadilhas conhecidas — leia antes de preencher:
#   HOST_URL    → deve apontar para a API, NÃO para o frontend.
#                 Errado : https://andrequice.store   (gera URLs de imagem com 404)
#                 Correto: https://api.andrequice.store
#
#   CORS_ORIGINS → lista separada por vírgula dos domínios do frontend e dashboard.
#                  Nunca inclua a URL da API aqui (ela não chama a si mesma via CORS).
# ─────────────────────────────────────────────────────────────────────────────

# ── Banco de dados ────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_USER=andrequice
POSTGRES_PASSWORD=SENHA_FORTE_AQUI
POSTGRES_DB=andrequice_production
POSTGRES_DB_TEST=andrequice_test

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_URL=redis://redis:6379/0

# ── Rails ─────────────────────────────────────────────────────────────────────
RAILS_ENV=production
RAILS_MASTER_KEY=CONTEUDO_DE_config/master.key
RAILS_MAX_THREADS=5

# ── URLs — ATENÇÃO aos comentários acima ─────────────────────────────────────
# HOST_URL → URL da API (usada para gerar URLs do Active Storage / imagens)
HOST_URL=https://api.andrequice.store

# FRONTEND_URL → URL do frontend público
FRONTEND_URL=https://andrequice.store

# CORS_ORIGINS → origens permitidas para requisições cross-origin à API
CORS_ORIGINS=https://andrequice.store,https://www.andrequice.store,https://dashboard.andrequice.store

# ── Autenticação ──────────────────────────────────────────────────────────────
JWT_SECRET=GERE_COM_rails_secret

# ── ActiveRecord Encryption ───────────────────────────────────────────────────
# Gere com: bundle exec rails db:encryption:init
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── MinIO (Active Storage) ────────────────────────────────────────────────────
STORAGE_ACCESS_KEY=andrequice
STORAGE_SECRET_KEY=SENHA_FORTE_AQUI
STORAGE_BUCKET=andrequice-prod
STORAGE_ENDPOINT=https://storage.andrequice.store

# ── SMTP / e-mail ────────────────────────────────────────────────────────────
# SMTP host, user, senha e endereço de suporte vivem em
# source/backend/config/credentials.yml.enc (chaves smtp.* e mail.*).
# A VPS só precisa exportar RAILS_MASTER_KEY.

# ── Melhor Envio ──────────────────────────────────────────────────────────────
ME_CLIENT_ID=
ME_CLIENT_SECRET=

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Seeds ────────────────────────────────────────────────────────────────────
ADMIN_SEED_PASSWORD=SENHA_ADMIN_INICIAL
