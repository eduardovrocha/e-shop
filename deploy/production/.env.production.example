# ─── Andrequicé — Variáveis de ambiente de produção ──────────────────────────
# Copiar para /home/deploy/andrequice/.env e preencher todos os campos
# marcados com SUBSTITUIR antes do primeiro deploy.
# NÃO commitar este arquivo com valores reais.
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
APP_VERSION=latest

# ── Rails ─────────────────────────────────────────────────────────────────────
RAILS_MASTER_KEY=SUBSTITUIR_MASTER_KEY
ADMIN_SEED_PASSWORD=SUBSTITUIR_SENHA_FORTE

# ── ActiveRecord Encryption (gerar com: bundle exec rails db:encryption:init) ─
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=SUBSTITUIR
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=SUBSTITUIR
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=SUBSTITUIR

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=andrequice
POSTGRES_PASSWORD=SUBSTITUIR_SENHA_FORTE
POSTGRES_DB=andrequice_production

# ── Redis ─────────────────────────────────────────────────────────────────────
# (sem configuração extra — container interno usa padrões do compose)

# ── Object Storage (MinIO self-hosted via Docker Compose) ────────────────────
# Estas credenciais são usadas tanto pelo MinIO quanto pelo Rails (Active Storage).
# STORAGE_ACCESS_KEY é passado como MINIO_ROOT_USER no container MinIO;
# STORAGE_SECRET_KEY é passado como MINIO_ROOT_PASSWORD. Mantenha os valores iguais.
STORAGE_ACCESS_KEY=andrequice
STORAGE_SECRET_KEY=SUBSTITUIR_SENHA_FORTE
STORAGE_BUCKET=andrequice-prod
STORAGE_ENDPOINT=https://storage.andrequice.store

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_SUBSTITUIR
STRIPE_WEBHOOK_SECRET=whsec_SUBSTITUIR

# ── Melhor Envio ──────────────────────────────────────────────────────────────
ME_CLIENT_ID=SUBSTITUIR
ME_CLIENT_SECRET=SUBSTITUIR

# ── SMTP ──────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.exemplo.com
SMTP_PORT=587
SMTP_USERNAME=SUBSTITUIR
SMTP_PASSWORD=SUBSTITUIR_SENHA
SMTP_FROM=noreply@andrequice.store

# ── Servidor ──────────────────────────────────────────────────────────────────
# Número de workers Puma (default 2 — KVM 4 suporta até 4)
WEB_CONCURRENCY=2

# ── Auth ──────────────────────────────────────────────────────────────────────
# Gerar com: openssl rand -hex 64
JWT_SECRET=SUBSTITUIR_HEX_128

# ── URLs e CORS ───────────────────────────────────────────────────────────────
FRONTEND_URL=https://andrequice.store
CORS_ORIGINS=https://andrequice.store,https://dashboard.andrequice.store
HOST_URL=https://api.andrequice.store
SUPPORT_EMAIL=contato@andrequice.store

# ── Vite build args (baked into frontend/dashboard at build time) ─────────────
VITE_API_URL=https://api.andrequice.store/api/v1
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_SUBSTITUIR
VITE_SENTRY_DSN=https://SUBSTITUIR@sentry.io/SUBSTITUIR

# ── Sentry ────────────────────────────────────────────────────────────────────
SENTRY_DSN=https://SUBSTITUIR@sentry.io/SUBSTITUIR
