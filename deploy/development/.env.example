# PostgreSQL (instância no host)
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=andrequice_development

# Redis (instância no host)
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Stripe — credenciais ficam encriptadas em stripe_settings.
# Configure via /admin/stripe no dashboard.

# Backend
JWT_SECRET=dev_jwt_secret_change_me
# HOST_URL — URL base da API (nginx porta 80). start.sh detecta o IP local e sobrescreve automaticamente.
# Em produção aponta para https://api.andrequice.store
# Para sobrescrever manualmente (ex: IP fixo): HOST_URL=http://192.168.0.15
HOST_URL=http://localhost

# FRONTEND_URL — URL base da loja pública. Usada em links de rastreamento de pedido.
# Em dev aponta para o mesmo nginx que HOST_URL; em produção aponta para https://andrequice.store
FRONTEND_URL=http://localhost
# CORS_ORIGINS ignorado em development — cors.rb aceita qualquer IP privado automaticamente
CORS_ORIGINS=http://localhost:5173,http://localhost:3092

# API URL — caminho relativo para funcionar via nginx (mesma origem).
# O nginx em :80 roteia /api para o backend automaticamente.
# Não precisa de IP ou porta — não altere salvo necessidade específica.
VITE_API_URL=/api/v1

# Dashboard
VITE_APP_NAME=Andrequicé Admin

