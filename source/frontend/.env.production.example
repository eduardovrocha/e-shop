# ─── Frontend — variáveis de build de produção ───────────────────────────────
# Estes valores são injetados em tempo de build via --build-arg no Dockerfile.
# Em produção, NÃO criar este arquivo no servidor — os valores vêm do .env
# da raiz do projeto (deploy/production/.env) passados como build-args.
# Este arquivo serve apenas como documentação dos build-args necessários.
# ─────────────────────────────────────────────────────────────────────────────

VITE_API_URL=https://api.andrequice.store/api/v1
VITE_APP_NAME=Andrequicé
# Stripe publishable key is fetched at runtime from GET /api/v1/stripe/config.
# Configure credentials via /admin/stripe in the dashboard before payments.
VITE_SENTRY_DSN=https://SUBSTITUIR@sentry.io/SUBSTITUIR
VITE_DASHBOARD_URL=https://dashboard.andrequice.store

# ── Build info (injetado automaticamente pelo CI) ────────────────
VITE_APP_VERSION=0.1.0
VITE_BUILD_DATE=
