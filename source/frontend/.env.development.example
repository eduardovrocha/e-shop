# ─── Frontend — variáveis de desenvolvimento local ───────────────────────────
# Copiar para .env.development (não commitado).
# Usado pelo Vite ao rodar em modo development.
# ─────────────────────────────────────────────────────────────────────────────

# URL da API — acesso direto à porta do backend (sem nginx)
# Use http://localhost:3091/api/v1 para acessar pelo host
# Use http://<IP_LAN>:3091/api/v1 para acessar de outros dispositivos na rede
VITE_API_URL=http://localhost:3091/api/v1

VITE_APP_NAME=Andrequicé

# Chave pública Stripe (SOMENTE pk_test_ em desenvolvimento)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_SUBSTITUIR

VITE_DASHBOARD_URL=http://localhost:3092
