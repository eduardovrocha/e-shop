# ─── Backend — variáveis de desenvolvimento local (sem Docker) ───────────────
# Copiar para .env.development e preencher.
# Usado quando o backend roda fora do Docker (rails server direto).
# Quando rodando via Docker Compose, as variáveis vêm de deploy/development/.env
# ─────────────────────────────────────────────────────────────────────────────

RAILS_ENV=development

# PostgreSQL (host machine)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=andrequice_development
POSTGRES_DB_TEST=andrequice_test

# Redis (host machine)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# Stripe (modo teste)
STRIPE_SECRET_KEY=sk_test_SUBSTITUIR
STRIPE_WEBHOOK_SECRET=whsec_SUBSTITUIR

# Active Record Encryption (gerar com: bundle exec rails db:encryption:init)
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=

# Auth
JWT_SECRET=change_me_for_development

# CORS — portas onde o frontend e dashboard rodam localmente
CORS_ORIGINS=http://localhost:5173,http://localhost:3090

# URL base da API — controla geração de URLs do Active Storage
# Mantido em http://localhost por padrão; somente necessário ajustar
# quando acessando de outros dispositivos na rede local.
HOST_URL=http://localhost:3000

# Suporte
SUPPORT_EMAIL=contato@andrequice.store
