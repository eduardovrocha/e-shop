<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <title>Item cancelado e reembolsado</title>
</head>
<body style="margin:0;padding:0;background-color:#f8f5f0;font-family:Georgia,serif;">
  <table width="100%" cellpadding="0" cellspacing="0" style="background-color:#f8f5f0;padding:32px 16px;">
    <tr>
      <td align="center">
        <table width="600" cellpadding="0" cellspacing="0" style="max-width:600px;width:100%;background:#ffffff;border-radius:12px;overflow:hidden;box-shadow:0 2px 8px rgba(0,0,0,0.08);">
          <tr>
            <td style="background-color:#1a2744;padding:28px 40px;text-align:center;">
              <h1 style="margin:0;font-family:Georgia,serif;font-size:22px;color:#c9a84c;letter-spacing:1px;">
                <%= @store_name.upcase %>
              </h1>
              <p style="margin:6px 0 0;font-family:Arial,sans-serif;font-size:12px;color:#8899bb;letter-spacing:2px;text-transform:uppercase;">
                Item cancelado
              </p>
            </td>
          </tr>

          <tr>
            <td style="padding:32px 40px 16px;">
              <p style="margin:0;font-family:Arial,sans-serif;font-size:16px;color:#1a2744;">
                Olá <%= @order.customer_name.to_s.split.first.presence || "cliente" %>,
              </p>
              <p style="margin:12px 0 0;font-family:Arial,sans-serif;font-size:14px;color:#5a4a3a;line-height:1.6;">
                O item <strong><%= @product&.name %><%= @order_item.size ? " — Tamanho #{@order_item.size}" : "" %></strong>
                do seu pedido foi cancelado
                <% if @actor_type == "admin" %>pelo nosso time<% else %>a seu pedido<% end %>.
              </p>
            </td>
          </tr>

          <tr>
            <td style="padding:0 40px 24px;">
              <div style="background:#f8f5f0;border:1px solid #e8e0d4;border-radius:8px;padding:16px;">
                <p style="margin:0 0 8px;font-family:Arial,sans-serif;font-size:12px;color:#8a7560;text-transform:uppercase;letter-spacing:1px;font-weight:bold;">
                  Reembolso
                </p>
                <p style="margin:0;font-family:Arial,sans-serif;font-size:20px;color:#1a2744;font-weight:bold;">
                  R$ <%= format("%.2f", @refund_cents.to_i / 100.0) %>
                </p>
                <p style="margin:6px 0 0;font-family:Arial,sans-serif;font-size:12px;color:#8a7560;">
                  <%= @refund_percentage %>% do valor pago — enviado ao mesmo método de pagamento.
                  Deve aparecer no seu extrato em até 10 dias úteis.
                </p>
                <% if @reason.present? %>
                <p style="margin:10px 0 0;font-family:Arial,sans-serif;font-size:12px;color:#5a4a3a;">
                  <strong>Motivo:</strong> <%= @reason %>
                </p>
                <% end %>
              </div>
            </td>
          </tr>

          <tr>
            <td style="padding:0 40px 32px;text-align:center;">
              <a href="<%= @public_url %>"
                 style="display:inline-block;background-color:#c9a84c;color:#1a2744;font-family:Arial,sans-serif;font-size:14px;font-weight:bold;text-decoration:none;padding:14px 32px;border-radius:8px;letter-spacing:0.5px;">
                Ver Pedido
              </a>
              <p style="margin:16px 0 0;font-family:Arial,sans-serif;font-size:12px;color:#8a7560;">
                Pedido <strong style="color:#1a2744;"><%= @order.number %></strong>
              </p>
            </td>
          </tr>

          <tr>
            <td style="background-color:#f8f5f0;padding:20px 40px;text-align:center;border-top:1px solid #e8e0d4;">
              <p style="margin:0;font-family:Arial,sans-serif;font-size:10px;color:#c8bfb4;">
                <%= @store_name %> — <%= ENV.fetch("SUPPORT_EMAIL", "suporte@andrequice.com.br") %>
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
