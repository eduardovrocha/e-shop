# PostgreSQL (host machine)
POSTGRES_HOST=host.docker.internal
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=andrequice_development
POSTGRES_DB_TEST=andrequice_test

# Redis (host machine)
REDIS_HOST=host.docker.internal
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Application
JWT_SECRET=change_me_in_production
SUPPORT_EMAIL=suporte@example.com.br

# Active Record Encryption (generate with: rails db:encryption:init)
ACTIVE_RECORD_ENCRYPTION_PRIMARY_KEY=
ACTIVE_RECORD_ENCRYPTION_DETERMINISTIC_KEY=
ACTIVE_RECORD_ENCRYPTION_KEY_DERIVATION_SALT=
RAILS_MAX_THREADS=5
RAILS_ENV=development

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3001

# SMTP — required for order notification emails in staging/production
# Leave blank in development to disable email delivery (test: letter_opener or mailhog)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_DOMAIN=example.com
SMTP_USERNAME=user@example.com
SMTP_PASSWORD=
SMTP_AUTH=plain
SMTP_TLS=true

# Application URL (used in tracking links and mailer routes)
HOST_URL=https://example.com

# Sentry error monitoring (leave blank to disable)
SENTRY_DSN=

# Redis DB for cache (separate from Sidekiq's DB 0)
REDIS_DB_CACHE=1
